APP_ENV=development
HTTP_ADDR=127.0.0.1:8080
PUBLIC_WEB_URL=
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
TRUSTED_PROXIES=
DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@REGION.pooler.supabase.com:5432/postgres?sslmode=require
DB_MAX_CONNECTIONS=10
TOKEN_PEPPER=
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_TTL_HOURS=12
DISABLE_GUEST_TOKENS=false
COOKIE_SECURE=false
GUEST_COOKIE_TTL_HOURS=720
SUPABASE_STORAGE_ENDPOINT=https://PROJECT_REF.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_REGION=PROJECT_REGION
SUPABASE_STORAGE_BUCKET=oneshotonenight
SUPABASE_STORAGE_ACCESS_KEY=
SUPABASE_STORAGE_SECRET_KEY=
MAX_UPLOAD_BYTES=10485760
